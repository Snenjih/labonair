{
  "$schema": "https://biomejs.dev/schemas/1.x/schema.json",
  "organizeImports": { "enabled": true },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 110
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noConsoleLog": "off"
      },
      "style": {
        "useImportType": "warn"
      }
    }
  },
  "files": {
    "ignore": ["dist", "src-tauri/target", "node_modules", "*.d.ts"]
  }
}
